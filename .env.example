# Server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:4000

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crm

# Apply pending DB migrations automatically on server boot (idempotent).
# Set to false to run `npm run db:migrate` manually instead.
AUTO_MIGRATE=true

# JWT secrets (use long random strings in production)
JWT_ACCESS_SECRET=change-me-access-secret-please
JWT_REFRESH_SECRET=change-me-refresh-secret-please
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000

# Default platform super-admin (created by `npm run db:seed`).
# Change these in production — do NOT keep the defaults.
SEED_ADMIN_EMAIL=admin@crm.local
SEED_ADMIN_PASSWORD=Admin12345
SEED_ADMIN_FIRST_NAME=Platform
SEED_ADMIN_LAST_NAME=Admin

# Cookies
COOKIE_SECURE=false
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax

# SMTP (leave empty to use console mock in development)
# Gmail example: use App Password from https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=nurbekrasulov71@gmail.com
SMTP_PASS="yepfbahhyojqzyac"
# SMTP_PASS=yepf bahh yojq zyac
SMTP_FROM=CRM System <nurbekrasulov71@gmail.com>

